# Deployment target for fund-dashboard.
#
# Copy this to deploy/deploy.env (gitignored) and fill in real values.
# deploy.sh and backup.sh source it; nothing here is baked into the repo, so
# the production host/IP, SSH key path, and remote paths stay out of git.

# SSH login for the VPS.
VPS_USER=root
VPS_HOST=your.vps.host.or.ip
SSH_KEY=$HOME/path/to/your-key.pem

# Public domain fronted by Cloudflare (used only in post-deploy hints).
VPS_DOMAIN=fund.example.com

# Remote layout on the VPS.
REMOTE_SRC=/root/src/fund-dashboard
REMOTE_STACK=/root/stacks/dashboard

# Absolute path to the production fund.db on the VPS (used by backup.sh).
VPS_DB=/root/stacks/dashboard/data/fund.db
