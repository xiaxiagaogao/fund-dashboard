# Copy this to .env and fill in real values. .env is gitignored.

# === Required for snapshot / deposit / withdraw (live Binance reads) ===
# Create a Binance API key at https://www.binance.com/en/my/settings/api-management
# and ENABLE ONLY: "Enable Reading". Disable Trade, Withdraw, Universal Transfer.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# === Dashboard-owned SQLite (auto-created on first run) ===
FUND_DB_PATH=./data/fund.db

# === Required for list-fills only (admin view of nofx fills) ===
# Local dev: rsync the nofx data.db down once. Fill VPS host/key/paths from
# deploy/deploy.env (gitignored):
#   source deploy/deploy.env
#   rsync -e "ssh -i $SSH_KEY" \
#         "$VPS_USER@$VPS_HOST:/path/to/nofx/data.db" ./data/nofx_data.db
# In prod container: /nofx_ro/data.db (bind-mounted ro)
NOFX_DB_PATH=./data/nofx_data.db

# === Required when HTTP server runs (later phases) ===
JWT_SECRET=change-me-to-a-32-byte-random-string
HTTP_ADDR=:8090
